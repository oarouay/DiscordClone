spring:
  application:
    name: backend
  datasource:
    url: jdbc:postgresql://localhost:5432/discord_clone
    driver-class-name: org.postgresql.Driver
    username: postgres
    password: YOUR_POSTGRES_PASSWORD_HERE  # Replace with your actual password
  jpa:
    database-platform: org.hibernate.dialect.PostgreSQLDialect
    hibernate:
      ddl-auto: update
    show-sql: false

server:
  port: 8081

app:
  jwt:
    secret: your-secure-random-key-change-this-in-production
    expiration: 86400000
